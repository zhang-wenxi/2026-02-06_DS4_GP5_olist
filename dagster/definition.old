import os
import subprocess
import sys
from pathlib import Path

from dagster import (
    AssetExecutionContext, 
    Definitions, 
    define_asset_job, 
    asset, 
    AssetSelection,
)
from dagster_dbt import DagsterDbtTranslator, DbtCliResource, dbt_assets, DbtProject

# 1. Setup Project Paths
# Up 1 level from dagster/definition.py to find the .env and dbt folder
ROOT_DIR = Path(__file__).resolve().parents[1]
DBT_PROJECT_DIR = ROOT_DIR / "dbt_olist"

# 2. Environment Configuration Loader
def _load_dotenv():
    """Injects .env variables into process memory with UTF-8-SIG handling."""
    env_path = ROOT_DIR / ".env"
    if env_path.exists():
        with open(env_path, "r", encoding="utf-8-sig") as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                os.environ[key.strip()] = value.strip().strip('"').strip("'")

_load_dotenv()

# 3. Automated dbt Project Management
class CustomTranslator(DagsterDbtTranslator):
    """Translates dbt metadata into the Dagster UI."""
    def get_description(self, dbt_resource_props):
        return dbt_resource_props.get("description", "No description provided.")
    
# 3. Automated dbt Project Management
olist_project = DbtProject(
    project_dir=DBT_PROJECT_DIR,
    # Points to where manifest.json and catalog.json live
    packaged_project_dir=DBT_PROJECT_DIR / "target", 
)

# 4. Merged dbt Assets (Models + Asset Checks)
@dbt_assets(
    manifest=olist_project.manifest_path,
    dagster_dbt_translator=CustomTranslator()
)
def olist_dbt_assets(context: AssetExecutionContext, dbt: DbtCliResource):
    """Runs models first, then executes dbt_expectations tests."""
    # 1. Run Models
    yield from dbt.cli(["run", "--exclude", "package:dbt_expectations"], context=context).stream()
    # 2. Run Tests (shows up as Asset Checks on the nodes)
    yield from dbt.cli(["test", "--select", "package:dbt_expectations"], context=context).stream()

# 5. Visual Quality Gate 
@asset(
    deps=[olist_dbt_assets],
    group_name="quality"
)
def quality_gate():
    """Visual checkpoint: Ensures models and dbt_expectations are finished."""
    return "Tests Completed"

# 6. Docs Generation
@asset(
    deps=[quality_gate], 
    group_name="metadata"
)
def dbt_docs_asset():
    """Generates dbt docs after quality gate passes."""
    env = {**os.environ}
    subprocess.run(
        ["dbt", "docs", "generate"],
        check=True,
        cwd=str(DBT_PROJECT_DIR),
        env=env
    )

# 7. Pipeline Job Definition
olist_full_job = define_asset_job(
    name="run_full_pipeline",
    selection=AssetSelection.all()
)

# 8. Definitions Registry
defs = Definitions(
    assets=[olist_dbt_assets, quality_gate, dbt_docs_asset], 
    jobs=[olist_full_job],
    resources={
        "dbt": DbtCliResource(
            project_dir=os.fspath(DBT_PROJECT_DIR),
            target_path="target" # Use a relative path from the project_dir
        ),
    },
)
